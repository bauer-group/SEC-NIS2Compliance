{
  "name": "@bauer-group/nis2-compliance",
  "version": "0.7.0",
  "description": "NIS2 Compliance Documentation – BAUER GROUP",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "setup": "npm install",
    "update": "npm update",
    "outdated": "npm outdated",
    "audit": "npm audit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:ci": "npm ci && vitepress build docs",
    "docs:clean": "rimraf docs/.vitepress/dist docs/.vitepress/cache node_modules/.vitepress",
    "docs:serve": "vitepress serve docs --port 4173",
    "lint": "markdownlint-cli2 \"docs/**/*.md\"",
    "lint:fix": "markdownlint-cli2 --fix \"docs/**/*.md\"",
    "check:links": "linkinator docs/.vitepress/dist --recurse --skip \"^(?!http://localhost)\"",
    "validate": "npm run lint && npm run docs:build && npm run check:links",
    "ci": "npm ci && npm run lint && npm run docs:build",
    "prepare": "husky"
  },
  "lint-staged": {
    "docs/**/*.md": "markdownlint-cli2 --fix"
  },
  "overrides": {
    "smol-toml": ">=1.6.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "linkinator": "^7.6.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "rimraf": "^6.1.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-rss": "^0.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bauer-group/SEC-NIS2Compliance.git"
  },
  "author": "BAUER GROUP"
}
